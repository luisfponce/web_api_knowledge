# Copy this file to .env for local development. Do not commit .env.
# This file is the configuration contract shared by Python, Docker Compose,
# and CI/CD documentation. Replace placeholder values in real environments.

# Docker Compose host ports for local inspection.
MARIADB_HOST_PORT=3306
REDIS_HOST_PORT=6379

# Local MariaDB credentials used by docker-compose.yml.
MARIADB_ROOT_PASSWORD=replace_with_local_root_password
MARIADB_DATABASE=crud_data
MARIADB_USER=webapi_user
MARIADB_PASSWORD=replace_with_local_database_password

# Backend database URL. Compose has a local placeholder fallback, but keeping
# this value in .env ensures containers and direct Python runs stay aligned.
DB_URL=mariadb+mariadbconnector://webapi_user:replace_with_local_database_password@mariadb:3306/crud_data

# Redis settings for the backend container.
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PSW=replace_with_local_redis_password

# Mail/JWT settings. Use fake or isolated local credentials unless you are
# intentionally testing outbound email.
ENV_MAIL_USERNAME=test@example.com
ENV_MAIL_PASSWORD=replace_with_local_mail_app_password
ENV_MAIL_FROM=test@example.com
ENV_SECRET_KEY=replace_with_local_jwt_secret
